#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)"
EXAMPLE_DIR="${ROOT_DIR}/examples/knowledge-compiler"

cmd="${1:-}"
shift || true

case "${cmd}" in
  init)
    exec bash "${EXAMPLE_DIR}/scripts/init.sh" "$@"
    ;;
  ingest)
    exec bash "${EXAMPLE_DIR}/scripts/ingest.sh" "$@"
    ;;
  compile)
    exec bash "${EXAMPLE_DIR}/scripts/compile.sh" "$@"
    ;;
  ask)
    exec bash "${EXAMPLE_DIR}/scripts/ask.sh" "$@"
    ;;
  lint)
    exec bash "${EXAMPLE_DIR}/scripts/lint.sh" "$@"
    ;;
  *)
    echo "Usage: kowalski-cli extension run knowledge-compiler <init|ingest|compile|ask|lint> [args...]"
    exit 1
    ;;
esac
