#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)"
APP_PATH="${ROOT_DIR}/examples/knowledge-compiler"
KOWALSKI_API="${KOWALSKI_API:-http://127.0.0.1:3456}"

usage() {
  cat <<'EOF'
Usage:
  kowalski-cli extension run knowledge-compiler list
  kowalski-cli extension run knowledge-compiler validate
  kowalski-cli extension run knowledge-compiler run "<source>" [--question "<q>"]
  kowalski-cli extension run knowledge-compiler "can you check https://yarenty.com and get summary into obsidian?"
  kowalski-cli extension run knowledge-compiler delegate "<capability>" "<source>" [--question "<q>"]
  kowalski-cli extension run knowledge-compiler worker "<agent-id>" [--topic "<topic>"]
  kowalski-cli extension run knowledge-compiler proof

Federation:
  use `kowalski` / `/api/federation/*` with CLI operators (`kowalski-cli federation ...`)
EOF
}

cmd="${1:-}"
shift || true

case "${cmd}" in
  list)
    exec cargo run -q -p kowalski-cli -- agent-app list --path "${APP_PATH}"
    ;;
  validate)
    exec cargo run -q -p kowalski-cli -- agent-app validate --path "${APP_PATH}"
    ;;
  run)
    source="${1:-}"
    shift || true
    question=""
    if [[ "${1:-}" == "--question" ]]; then
      question="${2:-}"
    fi
    if [[ -z "${source}" ]]; then
      echo "run requires <source>"
      exit 1
    fi
    if [[ -n "${question}" ]]; then
      exec cargo run -q -p kowalski-cli -- agent-app run --path "${APP_PATH}" --api "${KOWALSKI_API}" --question "${question}" "${source}"
    fi
    exec cargo run -q -p kowalski-cli -- agent-app run --path "${APP_PATH}" --api "${KOWALSKI_API}" "${source}"
    ;;
  delegate)
    capability="${1:-}"
    source="${2:-}"
    shift 2 || true
    question=""
    if [[ "${1:-}" == "--question" ]]; then
      question="${2:-}"
    fi
    if [[ -z "${capability}" || -z "${source}" ]]; then
      echo "delegate requires <capability> <source>"
      exit 1
    fi
    if [[ -n "${question}" ]]; then
      exec cargo run -q -p kowalski-cli -- agent-app delegate --api "${KOWALSKI_API}" --question "${question}" "${capability}" "${source}"
    fi
    exec cargo run -q -p kowalski-cli -- agent-app delegate --api "${KOWALSKI_API}" "${capability}" "${source}"
    ;;
  worker)
    agent_id="${1:-}"
    shift || true
    topic=""
    if [[ "${1:-}" == "--topic" ]]; then
      topic="${2:-}"
    fi
    if [[ -z "${agent_id}" ]]; then
      echo "worker requires <agent-id>"
      exit 1
    fi
    if [[ -n "${topic}" ]]; then
      exec cargo run -q -p kowalski-cli -- agent-app worker --path "${APP_PATH}" --api "${KOWALSKI_API}" --topic "${topic}" "${agent_id}"
    fi
    exec cargo run -q -p kowalski-cli -- agent-app worker --path "${APP_PATH}" --api "${KOWALSKI_API}" "${agent_id}"
    ;;
  proof)
    exec cargo run -q -p kowalski-cli -- agent-app proof --path "${APP_PATH}" --api "${KOWALSKI_API}"
    ;;
  help|-h|--help|"")
    usage
    ;;
  *)
    # Natural-language shortcut:
    #   extension run knowledge-compiler "can you check https://example.com and summarize into obsidian?"
    natural="${cmd}"
    if [[ "$#" -gt 0 ]]; then
      natural="${natural} $*"
    fi
    source="$(printf '%s\n' "${natural}" | /usr/bin/python3 -c 'import re,sys; s=sys.stdin.read(); m=re.search(r"https?://\S+", s); print(m.group(0) if m else "")')"
    if [[ -z "${source}" ]]; then
      echo "Unknown command: ${cmd}"
      echo "Tip: include a URL in your request sentence (e.g. https://yarenty.com)."
      usage
      exit 2
    fi
    question="$(printf '%s' "${natural}")"
    exec cargo run -q -p kowalski-cli -- agent-app run --path "${APP_PATH}" --api "${KOWALSKI_API}" --question "${question}" "${source}"
    ;;
esac
